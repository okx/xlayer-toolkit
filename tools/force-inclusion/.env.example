# All values below are optional — they default to reading from devnet/.env
# and devnet/config-op/rollup.json. Only set these to override.

# PRIVATE_KEY=0x...          # defaults to RICH_L1_PRIVATE_KEY from devnet/.env
# L1_RPC_URL=http://...      # defaults to L1_RPC_URL from devnet/.env
# L2_RPC_URL=http://...      # defaults to L2_RPC_URL from devnet/.env
# ROLLUP_JSON_PATH=/path/... # defaults to ../../devnet/config-op/rollup.json
