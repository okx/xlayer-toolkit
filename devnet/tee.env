# ==============================================================================
# tee.env — TEE Dispute Game E2E 测试专用配置
# ==============================================================================
# 使用方式:
#   cp tee.env .tee.env
#   编辑 .tee.env 填写密钥和地址
#   source .tee.env

# --- 基础设施（从现有 devnet 继承） ---
L1_RPC_URL=http://localhost:8545
L1_RPC_URL_IN_DOCKER=http://l1-geth:8545
DOCKER_NETWORK=dev-op

# --- 现有合约地址（从 devnet 部署结果获取，需与 .env 中的值一致） ---
DISPUTE_GAME_FACTORY_ADDRESS=0x9fb19f214e8ec1c84c25eb954183bdd6b8d5032e

# --- 部署者账户（与 devnet 相同，拥有 factory admin 权限） ---
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- 资金来源（devnet L1 预置的有钱账户，用于给 proposer/challenger 转账） ---
RICH_L1_PRIVATE_KEY=0x4bbbf85ce3377467afe5d46f804f221813b2bb87f24d81f60f1fcdbf7cbf4356

# --- TEE Proposer ---
# 提案者，需要有 ETH 余额用于支付 gas + initBond
TEE_PROPOSER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
TEE_PROPOSER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# --- TEE Challenger（op-challenger 的防守方密钥） ---
# op-challenger TEE Actor 使用此密钥提交 prove 交易
TEE_CHALLENGER_PRIVATE_KEY=0x8b3a350cf5c34c9194ca9aa3f146b2b9afed22cd83d3c5f6a3f2f243ce220c01
TEE_CHALLENGER_ADDRESS=0x9965507D1a55bcC2695C58ba16FB37d819B0A4dc

# --- 外部挑战者（测试脚本用，模拟恶意挑战者发起 challenge） ---
TEE_EXTERNAL_CHALLENGER_PRIVATE_KEY=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a
TEE_EXTERNAL_CHALLENGER_ADDRESS=0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65

# --- TEE Mock Signer（ECDSA 签名密钥） ---
# Mock TEE Prover 用此密钥签名 BatchProof
# MockTeeProofVerifier 合约中注册此地址
# 生成方式: cast wallet new
TEE_MOCK_SIGNER_PRIVATE_KEY=0x2a871d0798f97d79848a013d4936a73bf4cc922c825d33c1cf7073dff6d409c6
TEE_MOCK_SIGNER_ADDRESS=0xa0Ee7A142d267C1f36714E4a8F75612F20a79720

# --- Docker 镜像 ---
TEE_OP_STACK_LOCAL_DIRECTORY=        # 本地 optimism 目录，为空则从远程 clone
TEE_OP_STACK_BRANCH=tz/dev/op-proposer
SKIP_TEE_OP_STACK_BUILD=true
TEE_OP_STACK_IMAGE_TAG=op-stack-tee:latest

TEE_CONTRACTS_LOCAL_DIRECTORY=
TEE_CONTRACTS_BRANCH=contract/tee-dispute-game
SKIP_TEE_CONTRACTS_BUILD=true
TEE_CONTRACTS_IMAGE_TAG=op-contracts-tee:latest

# --- Mock 组件（宿主机运行，非 Docker） ---
MOCKTEERPC_ADDR=:8090                # mockteerpc 监听地址
MOCKTEERPC_INIT_HEIGHT=1000000       # 初始区块高度（必须大于 anchor sequence number）
MOCK_TEE_PROVER_ADDR=:8690           # mock-tee-prover 监听地址
MOCK_TEE_PROVER_TASK_DELAY=2s

# --- TEE 合约参数 ---
TEE_GAME_TYPE=1960
TEE_MAX_CHALLENGE_DURATION=120       # 秒
TEE_MAX_PROVE_DURATION=60            # 秒
TEE_CHALLENGER_BOND=10000000000000000   # 0.01 ETH (wei)
TEE_INIT_BOND=20000000000000000         # 0.02 ETH (wei)
TEE_FALLBACK_TIMEOUT=300                # AccessManager fallback 秒

# --- 初始资金转账金额 ---
FUND_AMOUNT=10ether                  # 从 RICH_L1 给各角色转账的金额

# --- 游戏窗口（op-challenger 用） ---
GAME_WINDOW=600                      # 秒
